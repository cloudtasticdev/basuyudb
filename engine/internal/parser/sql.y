distinct_opt:
		{ $$ = false }
	| DISTINCT
		{ $$ = true }

target_list:
	target_el
		{ $$ = []*ast.ResTarget{$1} }
	| target_list ',' target_el
		{ $$ = append($1, $3) }

target_el:
	STAR
		{ $$ = &ast.ResTarget{Val: &ast.A_Star{}} }
