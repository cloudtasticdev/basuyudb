	SELECT distinct_opt target_list from_clause where_opt group_opt having_opt order_opt limit_opt offset_opt
		{
			$$ = &ast.SelectStmt{
				TargetList: $3,
				FromClause: $4,
				WhereClause: $5,
				GroupClause: $6,
				HavingClause: $7,
				SortClause: $8,
				LimitCount: $9,
				LimitOffset: $10,
