	str string
	ival int
	node ast.Node
	nodes []ast.Node
	resTargets []*ast.ResTarget
	resTarget *ast.ResTarget
	rangeVar *ast.RangeVar
	sortList []*ast.SortBy
	sortBy *ast.SortBy
	strs []string
