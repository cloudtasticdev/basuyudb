sort_el:
	expr
		{ $$ = &ast.SortBy{Node: $1, SortDir: 0} }
	| expr ASC
		{ $$ = &ast.SortBy{Node: $1, SortDir: 1} }
	| expr DESC
		{ $$ = &ast.SortBy{Node: $1, SortDir: 2} }

limit_opt:
		{ $$ = nil }
	| LIMIT expr
		{ $$ = $2 }

offset_opt:
		{ $$ = nil }
	| OFFSET expr
		{ $$ = $2 }

/* ----- INSERT ----- */
insert_stmt:
	INSERT INTO qualified_name insert_cols_opt VALUES '(' expr_list ')'
		{
			cols := make([]*ast.ResTarget, 0, len($4))
			for _, c := range $4 {
