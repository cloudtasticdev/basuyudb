top:
	stmt opt_semi
		{
			yylex.(*lexer).result = $1
		}

opt_semi:
		{ }
	| ';'
		{ }

stmt:
	select_stmt { $$ = $1 }
	| insert_stmt { $$ = $1 }
	| update_stmt { $$ = $1 }
	| delete_stmt { $$ = $1 }
	| create_stmt { $$ = $1 }
	| create_index_stmt { $$ = $1 }
	| drop_table_stmt { $$ = $1 }
	| truncate_stmt { $$ = $1 }
	| alter_table_stmt { $$ = $1 }
	| create_branch_stmt { $$ = $1 }
	| merge_branch_stmt { $$ = $1 }
	| drop_branch_stmt { $$ = $1 }

