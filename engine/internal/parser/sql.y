		{ $$ = &ast.MergeBranchStmt{SourceBranch: $3, TargetBranch: "main"} }

drop_branch_stmt:
	DROP BRANCH IDENT
		{ $$ = &ast.DropBranchStmt{BranchName: $3} }

/* ----- expressions ----- */
expr_list:
	expr
		{ $$ = []ast.Node{$1} }
	| expr_list ',' expr
		{ $$ = append($1, $3) }

