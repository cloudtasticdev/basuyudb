		{ $$ = &ast.JoinExpr{JoinType: ast.JOIN_CROSS, Larg: $1, Rarg: $4} }

join_type:
		{ $$ = ast.JOIN_INNER }
	| INNER
		{ $$ = ast.JOIN_INNER }
	| LEFT
		{ $$ = ast.JOIN_LEFT }
	| RIGHT
		{ $$ = ast.JOIN_RIGHT }
	| FULL
		{ $$ = ast.JOIN_FULL }

table_ref:
	qualified_name
		{ $$ = $1 }
	| qualified_name IDENT
		{ $1.Alias = &ast.Alias{AliasName: $2}; $$ = $1 }
	| qualified_name AS IDENT
		{ $1.Alias = &ast.Alias{AliasName: $3}; $$ = $1 }

where_opt:
		{ $$ = nil }
	| WHERE expr
		{ $$ = $2 }

group_opt:
		{ $$ = nil }
	| GROUP BY expr_list
		{ $$ = $3 }

having_opt:
		{ $$ = nil }
	| HAVING expr
		{ $$ = $2 }

order_opt:
		{ $$ = nil }
	| ORDER BY sort_list
