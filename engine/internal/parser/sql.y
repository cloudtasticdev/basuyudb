	DROP TABLE qualified_name
		{ $$ = &ast.DropStmt{Table: $3.RelName} }
	| DROP TABLE IF EXISTS qualified_name
		{ $$ = &ast.DropStmt{Table: $5.RelName, IfExists: true} }

